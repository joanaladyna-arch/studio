
{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "A premium book entry in the user's library.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "author": { "type": "string" },
        "authorId": { "type": "string" },
        "series": { "type": "string" },
        "seriesId": { "type": "string" },
        "volume": { "type": "string" },
        "publisher": { "type": "string" },
        "collection": { "type": "string" },
        "isbn": { "type": "string" },
        "publicationDate": { "type": "string" },
        "language": { "type": "string" },
        "status": { "type": "string", "enum": ["pal", "progress", "read", "dnf", "pause", "reread"] },
        "format": { "type": "string", "enum": ["papier", "ebook", "kindle", "kobo", "audio", "audible", "audiolib", "autre"] },
        "favorite": { "type": "boolean" },
        "dePlume": { "type": "boolean", "description": "Livre faisant partie de la collection prestigieuse De Plume." },
        "cover": { "type": "string" },
        "rank": { "type": "string", "enum": ["diamant", "royale", "doree", "argentee", "simple", "froissee", "brisee", "dnf"] },
        "genres": { "type": "array", "items": { "type": "string" } },
        "tropes": { "type": "array", "items": { "type": "string" } },
        "themes": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "pages": { "type": "number" },
        "progress": { "type": "number" },
        "pagesRead": { "type": "number" },
        "rating": { "type": "number" },
        "review": { "type": "string" },
        "favoriteQuote": { "type": "string" },
        "favoriteCharacters": { "type": "string" },
        "memorableScene": { "type": "string" },
        "emotions": { "type": "array", "items": { "type": "string" } },
        "dateAdded": { "type": "string", "format": "date-time" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "abandonDate": { "type": "string", "format": "date" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author", "status"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with reading goals and preferences.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "pseudo": { "type": "string" },
        "bio": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "annualGoal": { "type": "number" },
        "annualPageGoal": { "type": "number" },
        "annualHourGoal": { "type": "number" },
        "preferredGenres": { "type": "array", "items": { "type": "string" } },
        "preferredTropes": { "type": "array", "items": { "type": "string" } },
        "favoriteAuthor": { "type": "string" },
        "favoriteQuote": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/users/{userId}/books/{bookId}": {
      "schema": "Book",
      "description": "Collection of books in the user's library."
    }
  }
}
