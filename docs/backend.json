
{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "A book in the user's library.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "publisher": { "type": "string" },
        "isbn": { "type": "string" },
        "publicationDate": { "type": "string" },
        "series": { "type": "string" },
        "volume": { "type": "string" },
        "status": { "type": "string", "enum": ["pal", "progress", "read", "dnf", "pause", "reread"] },
        "format": { "type": "string", "enum": ["papier", "ebook", "audio"], "description": "Reading format of the book." },
        "favorite": { "type": "boolean" },
        "cover": { "type": "string" },
        "rank": { "type": "string", "enum": ["diamant", "royale", "doree", "argentee", "simple", "froissee", "brisee", "dnf"] },
        "genres": { "type": "array", "items": { "type": "string" } },
        "tropes": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "pages": { "type": "number" },
        "duration": { "type": "number", "description": "Duration in decimal hours for audiobooks." },
        "narrator": { "type": "string", "description": "Narrator for audiobooks." },
        "progress": { "type": "number" },
        "pagesRead": { "type": "number" },
        "rating": { "type": "number" },
        "review": { "type": "string" },
        "favoriteQuote": { "type": "string" },
        "favoriteCharacters": { "type": "string" },
        "memorableScene": { "type": "string" },
        "emotions": { "type": "array", "items": { "type": "string" } },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author", "status"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "A reading or listening note.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["lecture", "écoute"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "content", "date"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "The user's settings and reading goals.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "pseudo": { "type": "string" },
        "annualGoal": { "type": "number" },
        "theme": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "bio": { "type": "string" },
        "preferredFormat": { "type": "string", "enum": ["papier", "ebook", "audio"] },
        "preferredGenres": { "type": "array", "items": { "type": "string" } },
        "preferredTropes": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/users/{userId}/books/{bookId}": {
      "schema": "Book",
      "description": "Collection of books in the user's library."
    },
    "/users/{userId}/journal/{entryId}": {
      "schema": "JournalEntry",
      "description": "User's reading and listening notes."
    }
  }
}
