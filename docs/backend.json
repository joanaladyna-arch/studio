
{
  "entities": {
    "MasterBook": {
      "title": "MasterBook",
      "description": "Universal book metadata stored in the central database.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "author": { "type": "string" },
        "publisherId": { "type": "string" },
        "collectionId": { "type": "string" },
        "isbn10": { "type": "string" },
        "isbn13": { "type": "string" },
        "pageCount": { "type": "number" },
        "language": { "type": "string" },
        "publishedDate": { "type": "string" },
        "cover": { "type": "string" },
        "description": { "type": "string" },
        "genres": { "type": "array", "items": { "type": "string" } },
        "tropes": { "type": "array", "items": { "type": "string" } },
        "series": { "type": "string" },
        "volume": { "type": "string" },
        "source": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author"]
    },
    "UserBook": {
      "title": "UserBook",
      "description": "User's personal reading data linked to a MasterBook.",
      "type": "object",
      "properties": {
        "masterBookId": { "type": "string" },
        "status": { "type": "string", "enum": ["pal", "progress", "read", "dnf", "pause", "reread"] },
        "format": { "type": "string", "enum": ["papier", "ebook", "kindle", "kobo", "audio", "audible", "audiolib", "autre"] },
        "rating": { "type": "number" },
        "review": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "addedAt": { "type": "string", "format": "date-time" },
        "personalNotes": { "type": "string" },
        "favoriteQuotes": { "type": "array", "items": { "type": "string" } },
        "plumeRank": { "type": "string" }
      },
      "required": ["masterBookId", "status"]
    },
    "Publisher": {
      "title": "Publisher",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "website": { "type": "string" },
        "country": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/masterBooks/{bookId}": {
      "schema": "MasterBook",
      "description": "Central book repository."
    },
    "/publishers/{publisherId}": {
      "schema": "Publisher",
      "description": "Global publishers list."
    },
    "/users/{userId}/books/{bookId}": {
      "schema": "UserBook",
      "description": "User's personal library collection."
    }
  }
}
