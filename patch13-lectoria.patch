+  const cleanRawHtmlDescriptions = async () => {
+    if (!db) return;
+    setIsCleaningDescriptions(true);
+    let cleaned = 0;
+    let checked = 0;
+    try {
+      const snap = await getDocs(collection(db, "masterBooks"));
+      const writes: Promise<any>[] = [];
